generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum SubscriptionRole {
  free
  pro
  premium
}

model User {
  id                      Int                   @id @default(autoincrement())
  name                    String
  username                String                @unique
  email                   String                @unique
  password_hash           String
  subscription_role       SubscriptionRole      @default(free)
  subscription_expires_at DateTime?
  daily_goal              Int                   @default(5)
  coins                   Int                   @default(0)
  avatar_seed             String?
  google_id               String?               @unique
  streak                  Int                   @default(0)
  last_completed_date     DateTime?             @db.Date
  reset_password_token    String?
  reset_password_expires  DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  userExerciseAttempts    UserExerciseAttempt[]
  aiUsageDaily            AiUsageDaily[]

  @@map("users")
}

model Level {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  exercises Exercise[]

  @@map("levels")
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  subcategories Subcategory[]

  @@map("categories")
}

model Subcategory {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  categoryId  Int        @map("category_id")
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  exercises   Exercise[]

  @@unique([name, categoryId])
  @@map("subcategories")
}

model Exercise {
  id            Int                   @id @default(autoincrement())
  type          String
  title         String
  questionText  String                @map("question_text")
  options       Json?
  correctAnswer Json                  @map("correct_answer")
  audioUrl      String?               @map("audio_url")
  readingText   String?               @map("reading_text")
  levelId       Int                   @map("level_id")
  level         Level                 @relation(fields: [levelId], references: [id], onDelete: Cascade)
  subcategoryId Int                   @map("subcategory_id")
  subcategory   Subcategory           @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  attempts      UserExerciseAttempt[]

  @@map("exercises")
}

model UserExerciseAttempt {
  id             Int      @id @default(autoincrement())
  userAnswer     Json     @map("user_answer")
  totalGaps      Int      @map("total_gaps")
  correctGaps    Int      @map("correct_gaps")
  isFullyCorrect Boolean  @map("is_fully_correct")
  score          Float
  createdAt      DateTime @default(now()) @map("created_at")
  userId         Int      @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId     Int      @map("exercise_id")
  exercise       Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  attemptExplanation AttemptExplanation?

  @@map("user_exercise_attempts")
}

model AttemptExplanation {
  id         Int                @id @default(autoincrement())
  explanation String             @db.Text
  model      String
  attemptId  Int                @unique @map("attempt_id")
  attempt    UserExerciseAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now()) @map("created_at")

  @@map("attempt_explanations")
}

model AiUsageDaily {
  id       Int      @id @default(autoincrement())
  date     DateTime @db.Date
  used     Int      @default(0)
  userId   Int      @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("ai_usage_daily")
}
